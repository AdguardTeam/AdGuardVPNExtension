.root {
    padding-right: 16px;
}

.row {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.title {
    font-size: 16px;
    line-height: 1.3;
}

.subtitle {
    color: var(--text-description-description-default);
    font-size: 14px;
    line-height: 1.3;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
